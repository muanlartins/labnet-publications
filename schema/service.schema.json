{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labnet-publications/schemas/service.json",
  "title": "Service",
  "description": "One academic service activity — program committee, editorial board, jury/banca, advising, invited talk, event organization. Controlled vocabularies (role, society, region) are injected from data/tags.yaml at validation time.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "role", "member_id", "title", "sources", "last_verified"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Globally unique, kebab-case. Convention: <member-id>-<role-short>-<venue-short>-<year>. Must equal the YAML filename stem."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable one-liner, e.g., 'Program Committee, BRACIS 2024' or 'PhD thesis jury for Jane Doe, UFRJ 2023'."
    },
    "role": { "type": "string" },
    "member_id": {
      "type": "string",
      "description": "The LabNet member who performed this service."
    },
    "year": { "type": ["integer", "null"], "minimum": 1900, "maximum": 2100 },
    "year_start": { "type": ["integer", "null"], "minimum": 1900, "maximum": 2100 },
    "year_end": { "type": ["integer", "null"], "minimum": 1900, "maximum": 2100 },
    "date": { "type": ["string", "null"], "format": "date" },
    "venue": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "short_name": { "type": "string" },
        "full_name": { "type": "string" },
        "type": { "type": "string", "enum": ["journal", "conference", "workshop", "symposium", "book", "magazine", "website", "institution", "other"] },
        "edition": { "type": ["string", "null"] },
        "series_id": { "type": ["string", "null"] },
        "society": { "type": ["string", "null"] }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "city": { "type": "string" },
        "country": { "type": "string" },
        "region": { "type": "string" }
      }
    },
    "related_work": {
      "type": ["object", "null"],
      "description": "Used for juries and advising — describes the work / person being evaluated or advised.",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["thesis", "dissertation", "qualifying_exam", "tcc", "research_project"] },
        "candidate_name": { "type": "string" },
        "candidate_institution": { "type": "string" },
        "title": { "type": "string", "description": "Thesis / dissertation / TCC title." },
        "title_en": { "type": "string" },
        "title_pt": { "type": "string" },
        "advisor": { "type": "string" },
        "graduation_year": { "type": ["integer", "null"] },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "areas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "url": { "type": "string", "format": "uri" },
    "notes": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "fetched_at"],
        "properties": {
          "source": { "type": "string" },
          "url": { "type": "string" },
          "source_id": { "type": "string" },
          "fetched_at": { "type": "string", "format": "date" }
        }
      }
    },
    "last_verified": { "type": "string", "format": "date" },
    "verified_by": { "type": "string" },
    "added_at": { "type": "string", "format": "date" }
  }
}
