{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labnet-publications/schemas/publication.json",
  "title": "Publication",
  "description": "One authored work — journal article, conference paper, book chapter, thesis, technical report, preprint, poster, etc. Controlled vocabularies (type, areas, language, society) are injected from data/tags.yaml at validation time.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "authors", "year", "type", "sources", "last_verified"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Globally unique, kebab-case. Convention: <first-labnet-author-last>-<short-title-slug>-<year>. Must equal the YAML filename stem."
    },
    "title": { "type": "string", "minLength": 1 },
    "title_en": { "type": "string", "description": "English title if the primary title is in another language." },
    "title_pt": { "type": "string", "description": "Portuguese title if the primary title is in another language." },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "position"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "description": "Author name as listed on the publication." },
          "position": { "type": "integer", "minimum": 1, "description": "1-based position in the author list." },
          "member_id": { "type": ["string", "null"], "description": "LabNet member id if this author is in our directory." },
          "affiliation": { "type": ["string", "null"] },
          "orcid": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$" },
          "is_corresponding": { "type": "boolean" }
        }
      }
    },
    "authors_labnet": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Denormalized list of LabNet member ids among authors — makes per-member filtering cheap. Must be a subset of authors[].member_id."
    },
    "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
    "month": { "type": ["integer", "null"], "minimum": 1, "maximum": 12 },
    "date": { "type": ["string", "null"], "format": "date" },
    "type": { "type": "string" },
    "venue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "short_name": { "type": "string" },
        "full_name": { "type": "string" },
        "type": { "type": "string", "enum": ["journal", "conference", "workshop", "symposium", "book", "magazine", "website", "institution", "other"] },
        "edition": { "type": ["string", "null"] },
        "series_id": { "type": ["string", "null"], "description": "Optional link to a canonical venue in the calendar repo (by series_id)." },
        "society": { "type": ["string", "null"] }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "city": { "type": "string" },
        "country": { "type": "string" },
        "region": { "type": "string" }
      }
    },
    "volume": { "type": "string" },
    "issue": { "type": "string" },
    "number": { "type": "string" },
    "pages": { "type": "string", "description": "e.g., '11-20', 'e1234', 'Article 42'." },
    "publisher": { "type": "string" },
    "language": { "type": "string", "enum": ["en", "pt", "es", "fr", "de", "other"] },
    "areas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "identifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "doi": { "type": "string" },
        "isbn": { "type": "string" },
        "issn": { "type": "string" },
        "arxiv_id": { "type": "string" },
        "scopus_id": { "type": "string" },
        "dblp_key": { "type": "string" },
        "openalex_id": { "type": "string" },
        "semantic_scholar_id": { "type": "string" },
        "sbc_sol_id": { "type": "string" }
      }
    },
    "url": { "type": "string", "format": "uri", "description": "Primary access URL." },
    "pdf_url": { "type": "string", "format": "uri" },
    "bibtex_url": { "type": "string", "format": "uri" },
    "abstract": { "type": "string" },
    "citation_count": { "type": ["integer", "null"], "minimum": 0, "description": "Optional snapshot — sources disagree; not load-bearing." },
    "notes": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "fetched_at"],
        "properties": {
          "source": { "type": "string", "description": "Source id from tags.sources, e.g., 'openalex', 'dblp', 'sbc_sol'." },
          "url": { "type": "string" },
          "source_id": { "type": "string", "description": "ID of this work within the source's namespace." },
          "fetched_at": { "type": "string", "format": "date" }
        }
      }
    },
    "last_verified": { "type": "string", "format": "date" },
    "verified_by": { "type": "string" },
    "added_at": { "type": "string", "format": "date" }
  }
}
